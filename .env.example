# Copy this file to `.env` and fill in your Supabase project values.
# Dashboard: https://supabase.com/dashboard/project/_/settings/api

# Project URL (public — safe in browser)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Anon / publishable key (public — safe in browser with RLS enabled)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key (SECRET — seed scripts only, never in zazu.html or client code)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: path to word JSON (defaults to ./zazu-words.json)
ZAZU_WORDS_JSON=./zazu-words.json
